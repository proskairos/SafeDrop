# SafeDrop Custodian Agent Environment Variables

# Your Filecoin Calibration testnet private key (hex, with or without 0x prefix)
# Get this from your wallet (e.g., MetaMask) for the testnet network
AGENT_PRIVATE_KEY=your_private_key_here

# Database Encryption Key (64-char hex for AES-256)
# Generate one: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=your_encryption_key_here

# Server Configuration
PORT=3003
# Use '/socket.io' for all modes (standard Socket.IO path)
SOCKET_PATH=/socket.io

# Contract Address (Filecoin Calibration)
CONTRACT_ADDRESS=0x06f14713198eA009fC98246164159e41C7Ec3A0B

# RPC URL (optional - uses default if not set)
# Fallback RPCs for reliability
# RPC_URL=https://api.calibration.node.glif.io/rpc/v1
RPC_URL=https://rpc.ankr.com/filecoin_testnet

# Poll Interval (optional - default 30000ms)
POLL_INTERVAL=30000
